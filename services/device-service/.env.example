# Device Service — copy to .env and fill in real values
PORT=3005
NODE_ENV=development

MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/dbname

# Gmail SMTP credentials (use an App Password, not your main password)
EMAIL_USER=you@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM="Zero Trust Security <you@gmail.com>"

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5002
