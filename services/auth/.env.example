# ─────────────────────────────────────────────
# Auth Service — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Node environment (development | production)
NODE_ENV=development

# Server port (default: 5000)
PORT=5000

# MongoDB connection string (Atlas or local)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT secrets — use long, random strings in production
JWT_SECRET=your_super_secret_jwt_key_here
REFRESH_SECRET=your_super_secret_refresh_key_here

# AES-256 encryption key for storing refresh tokens securely in DB
ENCRYPTION_KEY=your_32_char_or_longer_encryption_key

# Bootstrap superadmin credentials (created on first startup if no superadmin exists)
SUPERADMIN_EMAIL=superadmin@yourdomain.com
SUPERADMIN_PASSWORD=StrongPassword@123
