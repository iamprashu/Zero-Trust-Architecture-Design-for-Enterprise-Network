# Auth Service — copy to .env and fill in real values
PORT=5000
NODE_ENV=development

JWT_SECRET=change_me_jwt_secret
REFRESH_SECRET=change_me_refresh_secret

SUPERADMIN_EMAIL=admin@yourdomain.com
SUPERADMIN_PASSWORD=change_me_password

MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/dbname

# URL of the device-service (for OTP dispatch during login)
DEVICE_SERVICE_URL=http://localhost:3005

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5002
