# Auth Service
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=
REFRESH_SECRET=

# Superadmin seed
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# MongoDB
MONGO_URI=

# Device Service URL (used by auth service to send OTPs during login)
DEVICE_SERVICE_URL=http://localhost:3005

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost

# ── Zero-Trust Session Security ──────────────────────────────────────────────
# Salt used to hash OTP device User-Agent fingerprints.
# Binds an OTP session to the browser/machine that created it.
# 3 mismatches from a different UA → security lockout (admin-gated unlock).
#
# Generate a strong value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# WARNING: Changing this in production invalidates ALL active OTP device
# fingerprints — affected users will need to re-authenticate on their next request.
FINGERPRINT_SALT=