# Auth Service
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=
REFRESH_SECRET=

# Superadmin seed
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# MongoDB
MONGO_URI=

# Device Service URL (used by auth service to send OTPs during login)
DEVICE_SERVICE_URL=http://localhost:3005

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost