# ─────────────────────────────────────────────
# Root Workspace — Shared Environment Variables
# Shared values across the monorepo workspace.
# Each service also has its own .env.example.
# ─────────────────────────────────────────────

# Shared MongoDB URI (used by the @repo/db package)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
