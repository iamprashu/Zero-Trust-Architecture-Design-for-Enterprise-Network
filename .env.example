# ─────────────────────────────────────────────
# Root Workspace — Shared Environment Variables
# Shared values across the monorepo workspace.
# Each service also has its own .env.example.
# ─────────────────────────────────────────────

# Shared MongoDB URI (used by the @repo/db package)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# WebAuthn (FIDO2) Configuration
WEBAUTHN_RP_NAME=NexusBank
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost

# OTP Device Fingerprint Salt (Zero-Trust Session Security)
# Used to salt SHA-256 hashes of User-Agent strings for OTP device binding.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production — changing this value invalidates all existing OTP device fingerprints.
FINGERPRINT_SALT=9cca7cb27666185a167a54afbcbf779cebd538dded92b4f84c026a260829fb30